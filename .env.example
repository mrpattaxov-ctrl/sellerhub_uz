# Database
# PostgreSQL is required for every runtime.
# For local `python app.py`, point DATABASE_URL at your local PostgreSQL host.
# Docker Compose overrides DATABASE_URL inside the app container to use the `db` service.
#
# Port:
#   5432 -> direct to Postgres (local dev, default).
#   6432 -> PgBouncer (production VPS). To cut over, change the port inside
#           DATABASE_URL from :5432 to :6432 (no other change needed).
#           App-side: prepared statements are already disabled in
#           extensions.py so transaction-pool mode is safe.
DATABASE_URL=postgresql+psycopg://uzum:YOUR_PASSWORD@127.0.0.1:5432/uzum
POSTGRES_PASSWORD=uzum_secret_change_me

# psycopg3 auto-prepare threshold. Leave as 'none' whenever the app talks
# to PgBouncer in transaction mode. Set to an integer only if you're
# bypassing PgBouncer and want the driver's default behaviour.
DB_PREPARE_THRESHOLD=none

# App
APP_PORT=5000
SECRET_KEY=change-me-to-a-random-string
ENABLE_DEBUG_ROUTES=false
APP_TIMEZONE=Asia/Tashkent
APP_TZ_OFFSET_HOURS=5

# Finance sync
FINANCE_REFRESH_DAYS=45

# Hourly sales burst fetch
# Fetch the previous closed hour for ALL shops in parallel before sending
# hourly Telegram sales notifications. This makes hourly sales notifications
# independent from the staggered daily finance cache refresh schedule.
HOURLY_SALES_BURST_FETCH_ENABLED=1
HOURLY_SALES_BURST_FETCH_WORKERS=100

# PostgreSQL connection pool
# Sized for PgBouncer txn-mode fronting Postgres. Per Gunicorn/worker
# process SQLAlchemy keeps up to pool_size + max_overflow client-side
# connections to PgBouncer; PgBouncer then multiplexes them onto
# default_pool_size=25 real Postgres backends.
DB_POOL_SIZE=50
DB_MAX_OVERFLOW=100
DB_POOL_RECYCLE_SECONDS=1800

# Redis (shared cache for subscription settings/context + revoke blocklist)
# With password:   redis://:PASSWORD@127.0.0.1:6379/0
REDIS_URL=redis://127.0.0.1:6379/0

# Russian title fetching
FINANCE_FETCH_RU_TITLES=1
APP_PUBLIC_BASE_URL=https://your-domain.example
PAYME_MERCHANT_ID=
PAYME_MERCHANT_LOGIN=
PAYME_KEY=
PAYME_TEST_KEY=
PAYME_USE_TEST=1

# Telegram bot
# Get token from @BotFather, username is the bot's @handle (without @).
# When set, these env vars take priority over data/telegram_config.json.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# Verbose logging
FINANCE_SYNC_VERBOSE=0
