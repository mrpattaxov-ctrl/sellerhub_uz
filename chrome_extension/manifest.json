{
  "manifest_version": 3,
  "name": "Uzum Warehouse Token Sync",
  "version": "1.2",
  "description": "Automatically keeps your Uzum Warehouse app token fresh. Install once, forget forever.",

  "permissions": [
    "webRequest",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "*://api-seller.uzum.uz/*",
    "*://seller.uzum.uz/*",
    "http://*/*",
    "https://*/*"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "Uzum Token Sync"
  }
}
